{
  "info": {
    "name": "Brain API",
    "description": "Brain - AI Task Execution Engine API\n\nFlow: Create project → Create epic → Implement epic (AI decomposes into tasks) → Engine auto-executes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:7440"
    },
    {
      "key": "projectId",
      "value": "my-project"
    },
    {
      "key": "epicId",
      "value": "epic-01"
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-project\",\n  \"dir\": \"/tmp/my-project\",\n  \"tech\": \"node\"\n}"
            }
          }
        },
        {
          "name": "Create Project (with template override)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-frontend\",\n  \"dir\": \"/tmp/my-frontend\",\n  \"tech\": \"node\",\n  \"template\": \"frontend\"\n}"
            }
          }
        },
        {
          "name": "Register Existing Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"existing-project\",\n  \"dir\": \"/home/ubuntu/code/existing-project\",\n  \"tech\": \"node\"\n}"
            }
          }
        },
        {
          "name": "Get Project Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}"
          }
        },
        {
          "name": "Get Project Config",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/config"
          }
        },
        {
          "name": "Update Project Config",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/config",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"models\": {\n    \"test\": \"claude:sonnet\",\n    \"work\": \"claude:sonnet\",\n    \"review\": \"claude:opus\",\n    \"fix\": \"claude:sonnet\",\n    \"lint\": \"claude:haiku\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Partial merge — only send the fields you want to change. Omitted fields keep their current values."
          }
        }
      ]
    },
    {
      "name": "Epics",
      "item": [
        {
          "name": "Create Epic",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"User authentication\",\n  \"description\": \"Implement user auth with email/password signup, login, JWT tokens, and OAuth support for Gmail and GitHub.\"\n}"
            }
          }
        },
        {
          "name": "List Epics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics"
          }
        },
        {
          "name": "Update Epic",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Implement user auth with email/password signup and login. Use JWT for session tokens. Add OAuth for Gmail and GitHub. Include email validation on signup.\"\n}"
            }
          }
        },
        {
          "name": "Save Epic Plan",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"## Approach\\nUse Passport.js with JWT strategy.\\n\\n## Key Decisions\\n- bcrypt for password hashing\\n- Access + refresh token pattern\\n- OAuth via Passport strategies\\n\\n## Requirements\\n- POST /auth/signup with email validation\\n- POST /auth/login returns JWT pair\\n- GET /auth/me returns current user\\n- OAuth callbacks for Gmail and GitHub\\n\\n## Constraints\\n- No session storage, stateless JWT only\\n- Tokens expire in 15min (access) / 7d (refresh)\"\n}"
            },
            "description": "Save the curated final plan for this epic. This plan is fed to the decomposer when implementing. Typically written by the user after reviewing chat sessions."
          }
        },
        {
          "name": "Draft Plan from Sessions (AI)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/draft-plan",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_ids\": []\n}"
            },
            "description": "AI reads chat sessions and synthesizes a coherent plan draft. Pass session_ids to filter specific sessions, or send empty array / omit to use all sessions. Returns { plan: '...' } — user should review and save via PATCH."
          }
        },
        {
          "name": "Approve Plan (decompose into tasks)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/approve",
            "description": "User approves the final plan. AI decomposes the plan into tasks. Epic moves to 'ready' — tasks are visible but not yet executed. Move epic to 'implementing' (PATCH status) to start execution."
          }
        },
        {
          "name": "List Epic Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/tasks",
            "description": "List all tasks for this epic. Use this to show decomposed tasks on the epic board after approval."
          }
        },
        {
          "name": "Move Epic to Implement",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"implementing\"\n}"
            },
            "description": "Move epic from 'ready' to 'implementing'. This tells the engine to start picking up the epic's pending tasks. Equivalent to dragging the card to the Implement column."
          }
        },
        {
          "name": "Retry Failed Epic",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/retry",
            "description": "Resets all failed tasks in the epic back to pending so the engine picks them up again."
          }
        },
        {
          "name": "Stop Epic",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/stop",
            "description": "Stops all pending/running tasks in the epic. Kills the worker if a task from this epic is currently running."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List All Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "Retry Failed Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/task-01/retry",
            "description": "Resets a single failed task back to pending so the engine picks it up again."
          }
        },
        {
          "name": "Stop Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/task-01/stop",
            "description": "Stops a pending or running task. Kills the worker if this task is currently running."
          }
        }
      ]
    },
    {
      "name": "Execution",
      "item": [
        {
          "name": "Priority Boost (Run Project)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/run",
            "description": "Boosts priority of all pending tasks for this project so they get picked up next by the engine."
          }
        },
        {
          "name": "Stop Execution",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/stop"
          }
        },
        {
          "name": "Get Execution Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/status"
          }
        },
        {
          "name": "Engine Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/_queue"
          }
        },
        {
          "name": "SSE Event Stream",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/events",
            "description": "Server-Sent Events stream. In Postman, use 'Send and Download' or test via curl: curl -N {{baseUrl}}/projects/{{projectId}}/events"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Chat Message (new session, Claude)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"How should we implement this epic?\"\n}"
            },
            "description": "Start a new chat session with Claude (opus 4.6, default). Omit 'model' to use Claude. Returns sessionId, messageId, and model. Stream the response via the SSE endpoint."
          }
        },
        {
          "name": "Send Chat Message (new session, Codex)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"How should we implement this epic?\",\n  \"model\": \"codex\"\n}"
            },
            "description": "Start a new chat session with Codex using the repo default `gpt-5.3-codex`. Set model to `codex`. Allowed values are `claude`, `codex`, and `gpt-5.4`. Returns sessionId, messageId, and model."
          }
        },
        {
          "name": "Send Chat Message (new session, GPT-5.4)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"How should we implement this epic?\",\n  \"model\": \"gpt-5.4\"\n}"
            },
            "description": "Start a new chat session with `gpt-5.4` via the Codex CLI. Use model `gpt-5.4` when you want the non-codex GPT-5.4 option. Returns sessionId, messageId, and model."
          }
        },
        {
          "name": "Send Chat Message (continue session)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What about error handling?\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "description": "Continue an existing session. The model is locked to what was chosen when the session was created. Works for both active and finished sessions (finished sessions are reactivated)."
          }
        },
        {
          "name": "List Chat Sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/sessions",
            "description": "List all chat sessions for this epic, including model (claude or codex), message counts, and active status."
          }
        },
        {
          "name": "Chat Stream (SSE)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/stream",
            "description": "Server-Sent Events stream for the current chat response. Optionally pass ?sessionId= to target a specific session. Use curl for SSE: curl -N {{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/stream"
          }
        },
        {
          "name": "Session History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/sessions/{{sessionId}}/history",
            "description": "Get the full conversation history for a specific chat session."
          }
        },
        {
          "name": "Chat History (latest)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/history",
            "description": "Get the conversation history for the most recent chat session on this epic."
          }
        },
        {
          "name": "Delete Chat Session",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/sessions/{{sessionId}}",
            "description": "Permanently delete a chat session and all its messages. Cannot delete while a response is in progress."
          }
        },
        {
          "name": "Finish Chat",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/epics/{{epicId}}/chat/finish",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "description": "End a chat session. Pass sessionId to finish a specific session, or omit to finish the most recent active session. Aborts any in-flight response."
          }
        }
      ]
    }
  ]
}
